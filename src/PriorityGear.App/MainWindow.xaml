<Window x:Class="PriorityGear.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PriorityGear" Height="780" Width="1280" MinHeight="680" MinWidth="1100">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.8*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="RefreshButton" Content="Refresh" Width="88" Margin="0,0,8,0" Click="RefreshButton_Click" />
                <Button x:Name="StartButton" Content="Start" Width="88" Margin="0,0,8,0" Click="StartButton_Click" />
                <Button x:Name="StopButton" Content="Stop" Width="88" Margin="0,0,8,0" Click="StopButton_Click" />
                <Button x:Name="AddRuleButton" Content="Add rule" Width="104" Margin="0,0,8,0" Click="AddRuleButton_Click" />
                <Button x:Name="DeleteRuleButton" Content="Delete rule" Width="104" Margin="0,0,8,0" Click="DeleteRuleButton_Click" />
                <Button x:Name="SaveRulesButton" Content="Save rules" Width="104" Click="SaveRulesButton_Click" />
            </StackPanel>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextAlignment="Right" />
        </DockPanel>

        <DataGrid x:Name="ProcessGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70" />
                <DataGridTextColumn Header="Name" Binding="{Binding ExecutableName}" Width="150" />
                <DataGridTextColumn Header="Current" Binding="{Binding CurrentPriority}" Width="95" />
                <DataGridTextColumn Header="Rule" Binding="{Binding MatchedRule}" Width="150" />
                <DataGridTextColumn Header="Desired" Binding="{Binding DesiredPriority}" Width="95" />
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding Active}" Width="70" IsReadOnly="True" />
                <DataGridTextColumn Header="Last Applied" Binding="{Binding LastAppliedPriority}" Width="105" />
                <DataGridTextColumn Header="Last Result" Binding="{Binding LastResult}" Width="180" />
                <DataGridTextColumn Header="Last Time" Binding="{Binding LastApplyTime}" Width="90" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="Rules" FontWeight="SemiBold" Margin="0,12,0,6" />

        <DataGrid x:Name="RuleGrid" Grid.Row="3" AutoGenerateColumns="False" SelectionMode="Single" CellEditEnding="RuleGrid_CellEditEnding" CurrentCellChanged="RuleGrid_CurrentCellChanged">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="75" />
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName, UpdateSourceTrigger=LostFocus}" Width="160" />
                <DataGridTextColumn Header="Exe Name" Binding="{Binding ExecutableName, UpdateSourceTrigger=LostFocus}" Width="150" />
                <DataGridTextColumn Header="Full Path" Binding="{Binding FullPath, UpdateSourceTrigger=LostFocus}" Width="260" />
                <DataGridTextColumn Header="Path Suffix" Binding="{Binding PathSuffix, UpdateSourceTrigger=LostFocus}" Width="180" />
                <DataGridComboBoxColumn Header="Base" SelectedItemBinding="{Binding BasePriority, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                <DataGridComboBoxColumn Header="Active" SelectedItemBinding="{Binding ActivePriority, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                <DataGridCheckBoxColumn Header="Active Mode" Binding="{Binding ActiveModeEnabled, UpdateSourceTrigger=PropertyChanged}" Width="105" />
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes, UpdateSourceTrigger=LostFocus}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4" Text="Log" FontWeight="SemiBold" Margin="0,12,0,6" />

        <ListBox x:Name="LogList" Grid.Row="5" />
    </Grid>
</Window>
